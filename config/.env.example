# ============================================================
# Harmonia Engine — Environment Variables
# Copy to .env.local for local development.
# Do NOT commit .env.local or any file with real credentials.
# ============================================================

# ── App ───────────────────────────────────────────────────────────────────────

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Harmonia Engine

# ── Database ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://harmonia:password@localhost:5432/harmonia
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2

# ── Redis ────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=60

# ── Auth / JWT ────────────────────────────────────────────────────────────────

JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-secret-here-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Email (Resend) ────────────────────────────────────────────────────────────

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=testingpool@harmoniaengine.com
EMAIL_REPLY_TO=testingpool@harmoniaengine.com

# ── Storage (Cloudflare R2 / S3-compatible) ───────────────────────────────────

STORAGE_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=harmonia-assets
NEXT_PUBLIC_STORAGE_CDN_URL=https://cdn.harmoniaengine.com

# ── Push Notifications (Web Push / VAPID) ────────────────────────────────────

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:tech@harmoniaengine.com

# ── DNA Kit / MyHeritage integration ─────────────────────────────────────────

MYHERITAGE_API_KEY=your-myheritage-api-key
MYHERITAGE_WEBHOOK_SECRET=your-webhook-secret

# ── Admin ─────────────────────────────────────────────────────────────────────

ADMIN_EMAIL=avery@harmoniaengine.com
CRON_SECRET=your-cron-secret-for-verifying-scheduled-jobs

# ── Monitoring ────────────────────────────────────────────────────────────────

SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── GCP (Production only) ────────────────────────────────────────────────────

GCP_PROJECT_ID=harmonia-engine
GCP_REGION=europe-west1
